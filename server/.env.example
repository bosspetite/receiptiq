PORT=5000
CLIENT_ORIGIN=http://localhost:5173

# Used by the server to validate Supabase access tokens (Bearer ...)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Required only if you want AI extraction to work (server POST /api/upload/extract)
GEMINI_API_KEY=your-gemini-api-key
# Optional override (defaults inside server code)
# GEMINI_MODEL=gemini-2.5-flash
