# --- ReceiptIQ root / copy values into client/.env and server/.env as needed ---

# IMPORTANT:
# - Do NOT paste real keys into this file.
# - Put real values in: client/.env and server/.env (those files are gitignored).

# Server (server/.env)
PORT=5000
CLIENT_ORIGIN=http://localhost:5173

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

GEMINI_API_KEY=your-gemini-api-key
# Optional override (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Client (client/.env) — Vite requires VITE_ prefix
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Leave unset to use Vite proxy to same origin /api
# VITE_API_URL=http://localhost:5000/api
