# Copy this file to .env in the SAME folder (client/) and paste your real values.
# Get them from Supabase: Project Settings → API
#
# Restart Vite after changing (stop npm run dev, start again).

VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional — only if you are not using the Vite dev proxy
# VITE_API_URL=http://localhost:5000/api
